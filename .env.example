# Neon PostgreSQL - dapatkan dari dashboard neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx.neon.tech/sipatra?sslmode=require"

# NextAuth Secret - generate dengan: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-secret-yang-kuat"

# URL aplikasi
NEXTAUTH_URL="http://localhost:3000"
